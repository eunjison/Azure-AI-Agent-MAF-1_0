# =============================================
# PINE 2기 7회차 환경 변수 설정
# =============================================
# 사용법: cp .env.example .env  →  .env 파일에 실제 값 입력
# ⚠️  .env 파일은 절대 GitHub에 올리지 마세요!
# =============================================

# Azure OpenAI 엔드포인트 (강사에게 받은 값 입력)
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/

# Azure OpenAI API 키 (강사에게 받은 값 입력)
AZURE_OPENAI_API_KEY=your-api-key-here

# 모델 배포 이름 — MAF는 AZURE_OPENAI_MODEL 환경변수를 읽습니다
AZURE_OPENAI_MODEL=gpt-4o-mini

# API 버전 (기본값 사용 권장, 변경 불필요)
AZURE_OPENAI_API_VERSION=2024-08-01-preview
